<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardBook"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginTop="8dp"
    android:layout_marginBottom="8dp"
    android:clickable="true"
    android:focusable="true"
    style="@style/HiTechCardView">

    <View
        android:layout_width="4dp"
        android:layout_height="match_parent"
        android:background="@color/hi_tech_primary" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvBookTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/hi_tech_textPrimary"
                android:maxLines="2"
                android:ellipsize="end" />

            <ImageButton
                android:id="@+id/btnFavorite"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/btn_star_big_off"
                app:tint="@color/hi_tech_secondary"
                android:scaleType="centerInside"
                android:contentDescription="Toggle favorite" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvBookAuthor"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="@color/hi_tech_textSecondary"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipGenre"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                app:chipBackgroundColor="@color/hi_tech_primaryContainer"
                android:textColor="@color/hi_tech_primary"
                style="@style/Widget.Material3.Chip.Assist" />

            <TextView
                android:id="@+id/tvBookYear"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="@color/hi_tech_textSecondary"
                android:layout_marginStart="16dp" />

            <TextView
                android:id="@+id/tvBookPages"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="@color/hi_tech_textSecondary"
                android:layout_marginStart="16dp" />

        </LinearLayout>

        <RatingBar
            android:id="@+id/ratingBarSmall"
            style="?android:attr/ratingBarStyleSmall"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:numStars="5"
            android:stepSize="0.5"
            android:isIndicator="true"
            android:progressTint="@color/hi_tech_secondary"
            android:secondaryProgressTint="@color/hi_tech_secondary" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
