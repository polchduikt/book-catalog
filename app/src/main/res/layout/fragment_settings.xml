<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/hi_tech_background">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DATA BACKUP"
                android:textSize="12sp"
                android:textColor="@color/hi_tech_textSecondary"
                android:layout_marginBottom="8dp"
                android:layout_marginStart="8dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                style="@style/HiTechCardView">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Export your entire library to a JSON file on your device. You can use this to backup or transfer data."
                        android:textColor="@color/hi_tech_textPrimary"
                        android:textSize="14sp"
                        android:layout_marginBottom="16dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnExport"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:text="EXPORT TO JSON"
                        app:backgroundTint="@color/hi_tech_primary"
                        android:textColor="@color/hi_tech_onPrimary"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DATA RESTORE"
                android:textSize="12sp"
                android:textColor="@color/hi_tech_textSecondary"
                android:layout_marginBottom="8dp"
                android:layout_marginStart="8dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                style="@style/HiTechCardView">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Import a previously exported JSON backup file. Warning: This will add to your current library."
                        android:textColor="@color/hi_tech_textPrimary"
                        android:textSize="14sp"
                        android:layout_marginBottom="16dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnImport"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:text="IMPORT FROM JSON"
                        android:textColor="@color/hi_tech_secondary"
                        app:strokeColor="@color/hi_tech_secondary"
                        style="@style/Widget.Material3.Button.OutlinedButton"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
